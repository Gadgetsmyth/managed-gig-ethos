# clang-tidy configuration for MANUAL / CI runs (in-editor clang-tidy is disabled in
# .vscode/settings.json because Clang can't parse the avr-gcc framework headers).
# Tuned for bit-banged AVR firmware: register hex literals, short loop/bit variables,
# brace-less single statements, and intentional uint8_t truncation are all idiomatic
# here, so the noisiest style/pedantic checks are turned off to keep signal high.
Checks: >
  clang-analyzer-*,
  bugprone-*,
  performance-*,
  portability-*,
  misc-*,
  readability-*,
  -readability-magic-numbers,
  -readability-identifier-length,
  -readability-braces-around-statements,
  -readability-implicit-bool-conversion,
  -readability-isolate-declaration,
  -bugprone-narrowing-conversions,
  -bugprone-easily-swappable-parameters,
  -bugprone-throwing-static-initialization,
  -misc-include-cleaner,
  -misc-no-recursion,
  -misc-use-anonymous-namespace
WarningsAsErrors: ''
HeaderFilterRegex: '.*'
FormatStyle: file
